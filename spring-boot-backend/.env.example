# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/resumebuilder

# JWT Secret (use a secure random string, minimum 64 characters)
JWT_SECRET=YourSecureJWTSecretKeyForResumeBuilderApplicationMustBeAtLeast64CharactersLongForHS512Algorithm123456789

# CORS allowed origins (comma-separated). Include Next.js (3000) and/or Vite (5173).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
